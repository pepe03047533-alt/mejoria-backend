{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/promociones",
      "dest": "/frontend/dist/index.html"
    },
    {
      "src": "/results",
      "dest": "/frontend/dist/index.html"
    },
    {
      "src": "/admin",
      "dest": "/frontend/dist/index.html"
    },
    {
      "src": "/ml-best",
      "dest": "/frontend/dist/index.html"
    },
    {
      "src": "/profile",
      "dest": "/frontend/dist/index.html"
    },
    {
      "src": "/auth/callback",
      "dest": "/frontend/dist/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/$1"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "api/**"
    }
  }
}
